   "source": [
    "from sklearn.cluster import KMeans\n",
    "from sklearn.preprocessing import OneHotEncoder\n",
    "\n",
    "# Chuẩn bị dữ liệu global để dùng K-Means\n",
    "X_np = X.values if hasattr(X, 'values') else X\n",
    "scaler_global = StandardScaler()\n",
    "X_scaled_global = np.nan_to_num(scaler_global.fit_transform(X_np), nan=0.0)\n",
    "\n",
    "# Khởi tạo K-Means để tìm ra 10 vibe nhạc\n",
    "kmeans = KMeans(n_clusters=10, random_state=42, n_init=10)\n",
    "clusters = kmeans.fit_predict(X_scaled_global)\n",
    "\n",
    "# One-Hot Encoding cho cluster\n",
    "enc = OneHotEncoder(sparse_output=False, handle_unknown='ignore')\n",
    "cluster_ohe = enc.fit_transform(clusters.reshape(-1, 1))\n",
    "\n",
    "# Thêm cluster vào features gốc\n",
    "X_with_clusters = np.hstack([X_scaled_global, cluster_ohe])\n",
    "\n",
    "print(f\"K-Means Clustering hoàn tất!\")\n",
    "print(f\"   - Number of clusters: 10\")\n",
    "print(f\"   - Original features: {X_scaled_global.shape[1]}\")\n",
    "print(f\"   - Cluster one-hot features: {cluster_ohe.shape[1]}\")\n",
    "print(f\"   - Total features after adding clusters: {X_with_clusters.shape[1]}\")\n",
    "print(f\"   - Cluster distribution: {np.bincount(clusters)}\")"
   ]
  },
