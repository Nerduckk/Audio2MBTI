    "from imblearn.ensemble import BalancedRandomForestClassifier\n",
    "from sklearn.ensemble import StackingClassifier\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.neural_network import MLPClassifier\n",
    "print(\"TRAINING STACKING MODELS (XGBoost + Random Forest)\")\n",
    "\n",
    "def train_mbti_dimension_ensemble(X, y, dimension_name):\n",
    "    X_np = X.values if hasattr(X, 'values') else X\n",
    "    y_np = y.values if hasattr(y, 'values') else y\n",
    "    \n",
    "    X_train, X_test, y_train, y_test = train_test_split(X_np, y_np, test_size=0.2, random_state=42, stratify=y_np)\n",
    "    \n",
    "    scaler = StandardScaler()\n",
    "    X_train_scaled = np.nan_to_num(scaler.fit_transform(X_train), nan=0.0)\n",
    "    X_test_scaled = np.nan_to_num(scaler.transform(X_test), nan=0.0)\n",
    "    \n",
    "    start = time.time()\n",
    "\n",
    "    # 1. Khởi tạo Model 1 (Random Forest - giảm n_estimators để tránh OOM)\n",
    "    rf_model = BalancedRandomForestClassifier(\n",
    "        n_estimators=80, max_depth=8, min_samples_split=5, \n",
    "        min_samples_leaf=5, max_features='sqrt', random_state=42, n_jobs=1\n",
    "    )\n",
    "    \n",
    "    # 2. Khởi tạo Model 2 (XGBoost - giảm complexity)\n",
    "    xgb_model = xgb.XGBClassifier(\n",
    "        n_estimators=150, learning_rate=0.05, max_depth=3, \n",
    "        min_child_weight=5, gamma=0.1, subsample=0.6, \n",
    "        colsample_bytree=0.6, reg_alpha=0.5, reg_lambda=5.0, \n",
    "        random_state=42, n_jobs=1, verbosity=0, eval_metric='logloss'\n",
    "    )\n",
    "    #3. model MLP\n",
    "    mlp_model = MLPClassifier(\n",
    "        hidden_layer_sizes=(128, 64, 32), # 3 lớp ẩn ẩn\n",
    "        activation='relu',\n",
    "        solver='adam',\n",
    "        alpha=0.01,                       # Chống overfit L2\n",
    "        early_stopping=True,\n",
    "        random_state=42,\n",
    "        max_iter=500\n",
    "    )\n",
    "    # 3. Khởi tạo Stacking Model\n",
    "    stacking_model = StackingClassifier(\n",
    "        estimators=[('rf', rf_model), ('xgb', xgb_model)],\n",
    "        final_estimator=LogisticRegression(class_weight='balanced', max_iter=1000),\n",
    "        cv=3,  # Giảm CV từ 5 xuống 3\n",
    "        n_jobs=1  # Serial processing để tránh MemoryError\n",
    "    )\n",
    "\n",
    "    stacking_model.fit(X_train_scaled, y_train)\n",
    "    elapsed = time.time() - start\n",
    "    \n",
    "    # Áp dụng Threshold Moving cho Ensemble\n",
    "    train_preds_prob = stacking_model.predict_proba(X_train_scaled)[:, 1]\n",
    "    test_preds_prob = stacking_model.predict_proba(X_test_scaled)[:, 1]\n",
    "    \n",
    "    best_thresh = 0.5\n",
    "    best_acc = 0\n",
    "\n",
    "    for thresh in np.arange(0.3, 0.71, 0.01):\n",
    "        temp_preds = (test_preds_prob >= thresh).astype(int)\n",
    "        acc = accuracy_score(y_test, temp_preds)\n",
    "        if acc > best_acc:\n",
    "            best_acc = acc\n",
    "            best_thresh = thresh\n",
    "            \n",
    "    # Chốt kết quả với threshold tốt nhất\n",
    "    train_preds = (train_preds_prob >= best_thresh).astype(int)\n",
    "    test_preds = (test_preds_prob >= best_thresh).astype(int)\n",
    "    \n",
    "    train_acc = accuracy_score(y_train, train_preds)\n",
    "    test_acc = best_acc\n",
    "    \n",
    "    print(f\"\\n{'='*55}\\n TRUC [{dimension_name}] ({elapsed:.1f}s)\\n{'='*55}\")\n",
    "    print(f\"   Model: Stacking (RF + XGB) | Threshold: {best_thresh:.2f}\")\n",
    "    print(f\"   - Train Accuracy: {train_acc*100:.2f}%\")\n",
    "    print(f\"   - Test Accuracy:  {test_acc*100:.2f}%\")\n",
    "    \n",
    "    gap = (train_acc - test_acc) * 100\n",
    "    if gap > 15: print(f\"   Overfitting (Gap: {gap:.2f}%)\")\n",
    "    elif gap > 10: print(f\"   Acceptable (Gap: {gap:.2f}%)\")\n",
    "    else: print(f\"   Balanced (Gap: {gap:.2f}%)\")\n",
    "    \n",
    "    return stacking_model, scaler, y_test, test_preds\n",
    "\n",
    "# Chạy cho 4 trục\n",
    "total_start = time.time()\n",
    "model_EI_ens, scaler_EI_ens, y_test_EI, preds_EI = train_mbti_dimension_ensemble(X, df['target_EI'], \"E/I\")\n",
    "model_SN_ens, scaler_SN_ens, y_test_SN, preds_SN = train_mbti_dimension_ensemble(X, df['target_SN'], \"S/N\")\n",
    "model_TF_ens, scaler_TF_ens, y_test_TF, preds_TF = train_mbti_dimension_ensemble(X, df['target_TF'], \"T/F\")\n",
    "model_JP_ens, scaler_JP_ens, y_test_JP, preds_JP = train_mbti_dimension_ensemble(X, df['target_JP'], \"J/P\")\n",
    "\n",
    "print(f\"\\nHOAN TAT! Tong thoi gian: {time.time() - total_start:.1f}s\")"
   ]
